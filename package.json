{
  "name": "db-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "Mcp server for database query, through SSH tunnel",
  "bin": {
    "db-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "database",
    "mysql",
    "postgresql",
    "ssh-tunnel",
    "model-context-protocol"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "mysql2": "^3.6.0",
    "node-sql-parser": "^4.18.0",
    "pg": "^8.11.0",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.0",
    "ssh2": "^1.15.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pg": "^8.18.0",
    "@types/ssh2": "^1.15.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
